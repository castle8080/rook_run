@page "/run-stats"
@inject StravaActivitiesApiClient StravaActivitiesApiClient

<PageTitle>Run Stats</PageTitle>

<section class="run-stats-shell">
    <header class="run-stats-header">
        <h1>Run Stats</h1>
        <p>Month-by-month running summary for the last 13 months.</p>
    </header>

    @if (isLoading)
    {
        <div class="run-stats-loading">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading…</span>
            </div>
            <span class="run-stats-loading-label">Loading stats…</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(loadError))
    {
        <div class="alert alert-danger">@loadError</div>
    }
    else if (stats is not null)
    {
        @* YTD summary card *@
        <div class="ytd-card card mb-4">
            <div class="card-body ytd-body">
                <span class="ytd-title">@stats.YtdSummary.Year Year to Date</span>
                <span class="ytd-stat"><strong>@stats.YtdSummary.TotalRuns</strong> runs</span>
                <span class="ytd-sep" aria-hidden="true">·</span>
                <span class="ytd-stat"><strong>@FormatDist(stats.YtdSummary.TotalDistanceMiles)</strong></span>
            </div>
        </div>

        @* Desktop table — hidden on mobile via CSS *@
        <div class="table-responsive run-stats-table-wrap d-none d-md-block">
            <table class="table table-striped table-hover align-middle run-stats-table">
                <thead>
                    <tr>
                        <th scope="col">Month</th>
                        <th scope="col" class="text-end">Runs</th>
                        <th scope="col" class="text-end">Time</th>
                        <th scope="col" class="text-end">Distance</th>
                        <th scope="col">Longest</th>
                        <th scope="col">Fastest</th>
                        <th scope="col" class="text-end">Elevation</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in stats.Months)
                    {
                        <tr>
                            <td class="text-nowrap">@FormatMonthShort(m.Year, m.Month)</td>
                            <td class="text-end">@m.TotalRuns</td>
                            <td class="text-end text-nowrap">@FormatTime(m.TotalMovingTimeSeconds)</td>
                            <td class="text-end text-nowrap">@FormatDist(m.TotalDistanceMiles)</td>
                            <td class="text-nowrap">
                                @if (m.LongestRunDistanceMiles.HasValue)
                                {
                                    @($"{FormatDist(m.LongestRunDistanceMiles.Value)}")
                                    if (m.LongestRunPaceSecondsPerMile.HasValue)
                                    {
                                        <span class="stat-pace"> @@ @FormatPace(m.LongestRunPaceSecondsPerMile.Value)</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-nowrap">
                                @if (m.FastestRunPaceSecondsPerMile.HasValue)
                                {
                                    @FormatPace(m.FastestRunPaceSecondsPerMile.Value)
                                    if (m.FastestRunDistanceMiles.HasValue)
                                    {
                                        <span class="stat-dist"> (@FormatDist(m.FastestRunDistanceMiles.Value))</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end text-nowrap">@FormatElev(m.TotalElevationFeet)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Mobile card stack — hidden on desktop via CSS *@
        <div class="stats-card-grid d-md-none">
            @foreach (var m in stats.Months)
            {
                <div class="stats-month-card card">
                    <div class="card-header stats-month-header">
                        <strong>@FormatMonthLong(m.Year, m.Month)</strong>
                    </div>
                    <div class="card-body stats-month-body">
                        <div class="stats-row">
                            <span class="stats-label">Runs</span>
                            <span class="stats-value">@m.TotalRuns</span>
                        </div>
                        <div class="stats-row">
                            <span class="stats-label">Time</span>
                            <span class="stats-value">@FormatTime(m.TotalMovingTimeSeconds)</span>
                        </div>
                        <div class="stats-row">
                            <span class="stats-label">Distance</span>
                            <span class="stats-value">@FormatDist(m.TotalDistanceMiles)</span>
                        </div>
                        <div class="stats-row">
                            <span class="stats-label">Elevation</span>
                            <span class="stats-value">@FormatElev(m.TotalElevationFeet)</span>
                        </div>
                        <div class="stats-row">
                            <span class="stats-label">Longest</span>
                            <span class="stats-value">
                                @if (m.LongestRunDistanceMiles.HasValue)
                                {
                                    @FormatDist(m.LongestRunDistanceMiles.Value)
                                    if (m.LongestRunPaceSecondsPerMile.HasValue)
                                    {
                                        <span class="stat-pace"> @@ @FormatPace(m.LongestRunPaceSecondsPerMile.Value)</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </span>
                        </div>
                        <div class="stats-row">
                            <span class="stats-label">Fastest</span>
                            <span class="stats-value">
                                @if (m.FastestRunPaceSecondsPerMile.HasValue)
                                {
                                    @FormatPace(m.FastestRunPaceSecondsPerMile.Value)
                                    if (m.FastestRunDistanceMiles.HasValue)
                                    {
                                        <span class="stat-dist"> (@FormatDist(m.FastestRunDistanceMiles.Value))</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

@code {
    private RunStatsResponse? stats;
    private bool isLoading = true;
    private string? loadError;

    /// <inheritdoc />
    protected override async Task OnInitializedAsync()
    {
        try
        {
            stats = await StravaActivitiesApiClient.GetRunStatsAsync();
        }
        catch (Exception ex)
        {
            loadError = $"Failed to load run stats: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    /// <summary>
    /// Formats a total seconds value as a human-readable duration.
    /// Examples: 0 → "0m", 45 → "45m", 3600 → "1h 00m", 9720 → "2h 42m".
    /// </summary>
    /// <param name="totalSeconds">The duration in seconds.</param>
    /// <returns>A formatted duration string.</returns>
    private static string FormatTime(int totalSeconds)
    {
        if (totalSeconds <= 0) return "0m";
        var hours = totalSeconds / 3600;
        var minutes = (totalSeconds % 3600) / 60;
        return hours > 0
            ? $"{hours}h {minutes:D2}m"
            : $"{minutes}m";
    }

    /// <summary>
    /// Formats pace in seconds per mile as a min:sec/mi string.
    /// Example: 542.4 → "9:02/mi".
    /// </summary>
    /// <param name="secsPerMile">The pace in seconds per mile.</param>
    /// <returns>A formatted pace string.</returns>
    private static string FormatPace(double secsPerMile)
    {
        var totalSecs = (int)Math.Round(secsPerMile);
        var mins = totalSecs / 60;
        var secs = totalSecs % 60;
        return $"{mins}:{secs:D2}/mi";
    }

    /// <summary>
    /// Formats a distance in miles to one decimal place.
    /// Example: 62.3 → "62.3 mi".
    /// </summary>
    /// <param name="miles">The distance in miles.</param>
    /// <returns>A formatted distance string.</returns>
    private static string FormatDist(double miles) => $"{miles:F1} mi";

    /// <summary>
    /// Formats elevation in feet as a whole number with thousands separator.
    /// Example: 3420.7 → "3,421 ft".
    /// </summary>
    /// <param name="feet">The elevation in feet.</param>
    /// <returns>A formatted elevation string.</returns>
    private static string FormatElev(double feet) => $"{(int)Math.Round(feet):N0} ft";

    /// <summary>
    /// Formats a year and month as a long label for use in mobile cards.
    /// Example: (2026, 6) → "June 2026".
    /// </summary>
    /// <param name="year">The four-digit year.</param>
    /// <param name="month">The month number (1–12).</param>
    /// <returns>A formatted month label.</returns>
    private static string FormatMonthLong(int year, int month) =>
        new DateTime(year, month, 1).ToString("MMMM yyyy");

    /// <summary>
    /// Formats a year and month as a short label for use in the desktop table header.
    /// Example: (2026, 6) → "Jun '26".
    /// </summary>
    /// <param name="year">The four-digit year.</param>
    /// <param name="month">The month number (1–12).</param>
    /// <returns>A formatted short month label.</returns>
    private static string FormatMonthShort(int year, int month) =>
        new DateTime(year, month, 1).ToString("MMM ''yy");
}
