@page "/"

<PageTitle>RookRun</PageTitle>

<section class="landing-hero">
	<div class="hero-copy">
		<p class="kicker">RookRun Platform</p>
		<h1>Run Your Fitness Data Jobs From One Place</h1>
		<p class="hero-text">
			The API hosts your job engine and serves this client. Start with a guided overview, then launch jobs from the dashboard.
		</p>
		<div class="hero-actions">
			<a class="btn btn-primary btn-lg" href="jobs">Open Jobs</a>
			<a class="btn btn-outline-light btn-lg" href="api/jobs">View Jobs API</a>
		</div>
	</div>

	<div class="hero-card-grid">
		<article class="hero-card">
			<h2>Unified Host</h2>
			<p>HTTP APIs and WebAssembly client are served from the same backend for a clean deployment story.</p>
		</article>
		<article class="hero-card">
			<h2>Shared Contracts</h2>
			<p>Server and client use the same DTOs to reduce drift and keep integrations stable.</p>
		</article>
		<article class="hero-card">
			<h2>Operational Flow</h2>
			<p>List available jobs, run one on demand, and view execution status without leaving the app.</p>
		</article>
		<article class="hero-card">
			<h2>Run Stats</h2>
			<p>Month-by-month running summary for the last 13 months with pace, distance, and elevation trends.</p>
			<a class="btn btn-sm btn-outline-light mt-2" href="run-stats">View Stats</a>
		</article>
	</div>
</section>
