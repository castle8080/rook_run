@using RookRun.Contracts.Strava
@namespace RookRun.Web.Pages

<div class="table-responsive run-stats-table-wrap d-none d-md-block">
    <table class="table table-striped table-hover align-middle run-stats-table">
        <thead>
            <tr>
                <th scope="col">Month</th>
                <th scope="col" class="text-end">Runs</th>
                <th scope="col" class="text-end">Time</th>
                <th scope="col" class="text-end">Distance</th>
                <th scope="col">Longest</th>
                <th scope="col">Fastest</th>
                <th scope="col" class="text-end">Elevation</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var month in Months)
            {
                <tr>
                    <td class="text-nowrap">@RunStatsFormatting.FormatMonthShort(month.Year, month.Month)</td>
                    <td class="text-end">@month.TotalRuns</td>
                    <td class="text-end text-nowrap">@RunStatsFormatting.FormatTime(month.TotalMovingTimeSeconds)</td>
                    <td class="text-end text-nowrap">@RunStatsFormatting.FormatDist(month.TotalDistanceMiles)</td>
                    <td class="text-nowrap">
                        @if (month.LongestRunDistanceMiles.HasValue)
                        {
                            @RunStatsFormatting.FormatDist(month.LongestRunDistanceMiles.Value)
                            if (month.LongestRunPaceSecondsPerMile.HasValue)
                            {
                                <span class="stat-pace"> @@ @RunStatsFormatting.FormatPace(month.LongestRunPaceSecondsPerMile.Value)</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-nowrap">
                        @if (month.FastestRunPaceSecondsPerMile.HasValue)
                        {
                            @RunStatsFormatting.FormatPace(month.FastestRunPaceSecondsPerMile.Value)
                            if (month.FastestRunDistanceMiles.HasValue)
                            {
                                <span class="stat-dist"> (@RunStatsFormatting.FormatDist(month.FastestRunDistanceMiles.Value))</span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">-</span>
                        }
                    </td>
                    <td class="text-end text-nowrap">@RunStatsFormatting.FormatElev(month.TotalElevationFeet)</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    /// <summary>
    /// Gets or sets the ordered month stats displayed in the desktop table.
    /// </summary>
    [Parameter, EditorRequired]
    public required IReadOnlyList<RunMonthStatsDto> Months { get; set; }
}
