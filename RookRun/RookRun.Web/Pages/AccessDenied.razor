@page "/access-denied"

<PageTitle>Access Denied</PageTitle>

<section class="access-denied-container">
    <div class="alert alert-danger">
        <h1>Access Denied</h1>
        <p>
            Your account does not have permission to access this application.
        </p>
        <p>
            If you believe this is an error, please contact the application administrator.
        </p>
        <div class="mt-3">
            <a href="/auth/sign-out" class="btn btn-secondary">Sign Out</a>
        </div>
    </div>
</section>

