@using RookRun.Contracts.Strava
@namespace RookRun.Web.Pages

<div class="table-responsive activities-table-wrap">
    <table class="table table-striped table-hover align-middle activities-table">
        <thead>
            <tr>
                <th scope="col">Start (UTC)</th>
                <th scope="col">Start (Local)</th>
                <th scope="col">Name</th>
                <th scope="col">Type</th>
                <th scope="col">Elapsed</th>
                <th scope="col">Distance (mi)</th>
                <th scope="col">Pace (min/mi)</th>
                <th scope="col">Elevation (ft)</th>
                <th scope="col">Avg HR</th>
                <th scope="col">Max HR</th>
            </tr>
        </thead>
        <tbody>
            @if (Activities.Count == 0)
            {
                <tr>
                    <td colspan="10" class="text-center text-muted py-4">No activities match the current filters for this UTC date range.</td>
                </tr>
            }
            else
            {
                foreach (var activity in Activities)
                {
                    <tr>
                        <td>@ActivitiesFormatting.FormatUtcDate(activity.StartDate)</td>
                        <td>@ActivitiesFormatting.FormatLocalDate(activity.StartDateLocal)</td>
                        <td>@(string.IsNullOrWhiteSpace(activity.Name) ? "(untitled)" : activity.Name)</td>
                        <td>@ActivitiesFormatting.ResolveActivityType(activity)</td>
                        <td>@ActivitiesFormatting.FormatElapsedTime(activity.ElapsedTime)</td>
                        <td>@ActivitiesFormatting.FormatMiles(activity.Distance)</td>
                        <td>@ActivitiesFormatting.FormatPaceMinutesPerMile(activity.MovingTime, activity.Distance)</td>
                        <td>@ActivitiesFormatting.FormatElevationFeet(activity.TotalElevationGain)</td>
                        <td>@ActivitiesFormatting.FormatHeartRate(activity.AverageHeartrate)</td>
                        <td>@ActivitiesFormatting.FormatHeartRate(activity.MaxHeartrate)</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    /// <summary>
    /// Gets or sets the filtered activities displayed in the table.
    /// </summary>
    [Parameter, EditorRequired]
    public required IReadOnlyList<StravaActivityDto> Activities { get; set; }
}
