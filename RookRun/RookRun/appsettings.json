{
  "StravaClient": {
    "ApiBaseUrl": "https://www.strava.com/api/v3",
  },
  "StravaTokenStore": {
    "UseWindowsDpapi": true
  },
  "StravaOAuthClient": {
    "AuthorizationBaseUrl": "https://www.strava.com/oauth",
    "ClientId": "",
    "ClientSecret": ""
  },
  "ObjectStore": {
    "Type": "AzureBlob",
    "AzureBlob": {
      "Authentication": "SharedKey",
      "ServiceUri": "https://rookrun.blob.core.windows.net/",
      "ContainerName": "rookrun",
      "AccountName": "rookrun",
      "RootPrefix": ""
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
